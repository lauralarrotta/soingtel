# ===========================================
# CONFIGURACIÓN LOCAL (DESARROLLO)
# ===========================================
# Copiar este archivo a .env y configurar según necesidad
# NO committing este archivo con credenciales reales

# ===========================================
# SERVIDOR
# ===========================================
PORT=3001
NODE_ENV=development

# ===========================================
# BASE DE DATOS POSTGRESQL
# ===========================================
# Opción 1: Docker local
# DATABASE_URL=postgres://postgres:soingtel_pass@localhost:5432/soingtel

# Opción 2: Supabase u otro proveedor
# DATABASE_URL=postgres://user:password@host:port/dbname
DATABASE_URL=postgres://postgres:password@localhost:5432/soingtel
DATABASE_SSL=false

# ===========================================
# SEGURIDAD
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ===========================================
# USUARIOS DE AUTENTICACIÓN
# ===========================================
# Formato: usuario:contraseña:rol (separados por coma)
USERS=soporte:soporte123:soporte,facturacion:facturacion123:facturacion,admin:admin123:admin

# ===========================================
# GOOGLE SHEETS (opcional)
# ===========================================
GOOGLE_SHEET_ID=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
