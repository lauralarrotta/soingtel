# ===========================================
# CONFIGURACIÓN DEL SERVIDOR
# ===========================================
PORT=3001
NODE_ENV=development

# ===========================================
# BASE DE DATOS POSTGRESQL
# ===========================================
DATABASE_URL=postgres://usuario:password@localhost:5432/soingtel
DATABASE_SSL=false

# ===========================================
# SEGURIDAD
# ===========================================
# Rate Limiting (en milisegundos)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS (separados por coma)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ===========================================
# USUARIOS DE AUTENTICACIÓN
# ===========================================
# Formato: usuario:contraseña:rol (separados por coma)
# Roles disponibles: admin, facturacion, soporte, basic
USERS=soporte:soporte123:soporte,facturacion:facturacion123:facturacion,admin:admin123:admin

# ===========================================
# GOOGLE SHEETS (opcional)
# ===========================================
GOOGLE_SHEET_ID=tu spreadsheet id aqui
GOOGLE_CLIENT_EMAIL=tu email@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="tu clave privada"
